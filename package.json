{
  "name": "brag-cv",
  "version": "0.1.0",
  "description": "CLI tool that generates personalized, ATS-friendly PDF resumes using AI",
  "type": "module",
  "scripts": {
    "generate": "tsx src/commands/generate.ts",
    "preview": "tsx src/commands/generate-preview.ts",
    "preview:en": "PREVIEW_LANG=en tsx src/commands/generate-preview.ts",
    "preview:pt": "PREVIEW_LANG=pt tsx src/commands/generate-preview.ts",
    "generate:manual": "tsx src/commands/generate-manual.ts",
    "compare": "tsx src/commands/generate-compare.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "ai": "^6.0.116",
    "dotenv": "^16.4.0",
    "pdfmake": "^0.2.15",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdfmake": "^0.2.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
